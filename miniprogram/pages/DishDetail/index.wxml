<view class="container">
  <!-- 菜品图片 -->
  <view class="dish-image-wrapper">
    <image class="dish-image" wx:if="{{dish.imageUrl || previewImageUrl}}" src="{{dish.imageUrl || previewImageUrl}}" mode="widthFix"></image>
    <image class="dish-image" wx:else src="/images/bba273d65e7e0a3ae9773c36c18acef1.jpg" mode="widthFix"></image>
  </view>

  <!-- 菜品信息卡片 -->
  <view class="dish-info-card">
    <view class="dish-name">{{dish.name}}</view>

    <view class="info-row">
      <text class="info-icon">👤</text>
      <text class="info-label">添加者</text>
      <text class="info-value">{{creatorName}}</text>
    </view>

    <view class="info-row">
      <text class="info-icon">📅</text>
      <text class="info-label">添加时间</text>
      <text class="info-value">{{dateText}}</text>
    </view>

    <view class="info-row" wx:if="{{dish.desc}}">
      <text class="info-icon">📝</text>
      <text class="info-label">备注</text>
      <text class="info-value">{{dish.desc}}</text>
    </view>
  </view>

  <!-- 菜谱区 -->
  <view class="recipe-card" wx:if="{{dish.ingredients || dish.steps}}">
    <view class="recipe-header">
      <view class="recipe-title-wrap">
        <text class="recipe-title">菜谱</text>
      </view>
      <view class="recipe-edit-chip" bindtap="editRecipeManual">
        <text>✏️ 编辑</text>
      </view>
    </view>

    <view class="recipe-meta" wx:if="{{dish.cookTime || dish.difficulty}}">
      <text class="meta-item" wx:if="{{dish.cookTime}}">⏱ {{dish.cookTime}}</text>
      <text class="meta-item" wx:if="{{dish.difficulty}}">🌶 {{dish.difficulty}}</text>
    </view>

    <view class="recipe-section" wx:if="{{dish.ingredients}}">
      <view class="recipe-section-title">🥬 食材</view>
      <view class="recipe-section-body">{{dish.ingredients}}</view>
    </view>

    <view class="recipe-section" wx:if="{{dish.steps}}">
      <view class="recipe-section-title">👩‍🍳 做法</view>
      <view class="recipe-section-body">{{dish.steps}}</view>
    </view>
  </view>

  <!-- 没有菜谱：空状态卡片 -->
  <view class="recipe-card recipe-empty-card" wx:else>
    <view class="recipe-header">
      <view class="recipe-title-wrap">
        <text class="recipe-title">菜谱</text>
      </view>
    </view>
    <view class="empty-body">
      <text class="empty-icon">📝</text>
      <text class="empty-title">还没有菜谱</text>
      <text class="empty-hint">写一份做法，下次做更方便</text>
    </view>
    <view class="empty-actions">
      <view class="empty-action" bindtap="editRecipeManual">
        <text>写菜谱</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <view class="btn-edit" bindtap="editDish">
      <text>编辑菜品</text>
    </view>
    <view class="btn-delete" bindtap="deleteDish">
      <text>删除菜品</text>
    </view>
  </view>
</view>
<bind-guard />
