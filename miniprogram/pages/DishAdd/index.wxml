<view class="container">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">{{isEdit ? '编辑菜品' : '添加菜品'}}</text>
    <text class="page-subtitle">{{isEdit ? '修改菜品信息' : '给小厨房添加新成员 ~'}}</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 图片上传 -->
    <view class="upload-card {{imageUrl ? 'has-image' : ''}}" bindtap="chooseImage">
      <image wx:if="{{imageUrl}}" class="preview-image" src="{{imageUrl}}" mode="widthFix"></image>
      <view wx:else class="upload-placeholder">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击上传菜品图片</text>
        <text class="upload-hint">支持从相册选择或拍照</text>
      </view>
      <!-- 清空图片：有图时显示在右上角 -->
      <view class="clear-image-btn" wx:if="{{imageUrl}}" catchtap="clearImage">
        <text>×</text>
      </view>
    </view>

    <!-- 菜品名称 -->
    <view class="input-card">
      <view class="input-label">
        <text class="label-icon">🍽️</text>
        <text class="label-text">菜品名称</text>
      </view>
      <input class="input-field" placeholder="给这道菜起个名字吧"
             placeholderClass="input-placeholder"
             bindinput="onNameInput" value="{{name}}" />
      <text class="input-counter">{{name.length}}/20</text>
    </view>

    <!-- 菜品分类 -->
    <view class="input-card">
      <view class="input-label">
        <text class="label-icon">📂</text>
        <text class="label-text">菜品分类</text>
      </view>
      <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-value">
          <text>{{categories[categoryIndex].icon}} {{categories[categoryIndex].name}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 菜品描述 -->
    <view class="input-card">
      <view class="input-label">
        <text class="label-icon">💬</text>
        <text class="label-text">一句话描述</text>
        <text class="label-optional">（选填，最多6字）</text>
      </view>
      <input class="input-field" placeholder="例如：超下饭"
             placeholderClass="input-placeholder"
             bindinput="onDescInput" value="{{description}}" />
      <text class="input-counter">{{description.length}}/6</text>
    </view>

    <!-- 菜谱（合到一张卡，跟其他字段卡片一致） -->
    <view class="input-card">
      <view class="input-label">
        <text class="label-icon">📖</text>
        <text class="label-text">菜谱</text>
        <text class="label-optional">（选填）</text>
      </view>

      <view class="recipe-subfield">
        <view class="subfield-label">
          <text class="subfield-icon">🥬</text>
          <text class="subfield-text">食材</text>
          <text class="subfield-hint">每行一项</text>
        </view>
        <textarea class="recipe-textarea" placeholder="例如：鸡蛋 2 个、番茄 1 个、生抽 1 勺"
                  placeholder-class="input-placeholder"
                  style="height: {{ingredientsHeight}}rpx"
                  bindinput="onIngredientsInput" value="{{ingredients}}"
                  disable-default-padding maxlength="-1" />
      </view>

      <view class="recipe-subfield">
        <view class="subfield-label">
          <text class="subfield-icon">👩‍🍳</text>
          <text class="subfield-text">做法</text>
          <text class="subfield-hint">每行一步</text>
        </view>
        <textarea class="recipe-textarea" placeholder="例如：1. 番茄切块 2. 鸡蛋打散 3. 油锅炒蛋"
                  placeholder-class="input-placeholder"
                  style="height: {{stepsHeight}}rpx"
                  bindinput="onStepsInput" value="{{steps}}"
                  disable-default-padding maxlength="-1" />
      </view>

      <view class="recipe-subfield recipe-inline-row">
        <view class="recipe-inline-field">
          <view class="subfield-label">
            <text class="subfield-icon">⏱</text>
            <text class="subfield-text">时长</text>
          </view>
          <picker mode="selector" range="{{cookTimeOptions}}" range-key="label" value="{{cookTimeIndex}}" bindchange="onCookTimeChange">
            <view class="picker-value">
              <text>{{cookTime}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="recipe-inline-field">
          <view class="subfield-label">
            <text class="subfield-icon">🌶</text>
            <text class="subfield-text">难度</text>
          </view>
          <picker mode="selector" range="{{difficultyOptions}}" value="{{difficultyIndex}}" bindchange="onDifficultyChange">
            <view class="picker-value">
              <text>{{difficulty}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <view class="btn-reset" bindtap="resetForm">重置</view>
    <view class="btn-save" bindtap="saveDish">{{isEdit ? '保存修改' : '保存菜品'}}</view>
  </view>
</view>
<bind-guard />
