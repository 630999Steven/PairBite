/* 添加菜品页样式 */

.container {
  padding-bottom: 160rpx;
}

/* 页面头部 */
.page-header {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%);
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 表单区域 */
.form-section {
  padding: 30rpx 24rpx;
}

/* 图片上传 */
.upload-card {
  position: relative;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.1);
  margin-bottom: 30rpx;
  /* 占位状态固定高度，避免框跳动 */
  height: 400rpx;
}

/* 有图片时让卡片按图片实际高度撑开（preview-image 用 widthFix 等比缩放） */
.upload-card.has-image {
  height: auto;
}

/* 清空图片按钮（叠在预览图右上角） */
.clear-image-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.clear-image-btn text {
  color: white;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 300;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  background: #FAFAFA;
  border: 4rpx dashed #E8F5E9;
  box-sizing: border-box;
}

.upload-icon {
  font-size: 60rpx;
  line-height: 1;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #999;
}

.preview-image {
  width: 100%;
  display: block;
}

/* 输入卡片 */
.input-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.1);
  margin-bottom: 30rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.label-optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 8rpx;
}

.input-field {
  width: 100%;
  font-size: 32rpx;
  color: #333;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #E8F5E9;
}

.input-placeholder {
  color: #CCC;
}

.input-counter {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 子字段（食材/做法/时长+难度），用淡色分割线区隔 */
.recipe-subfield {
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 2rpx solid #F0F7EE;
}

.recipe-subfield:first-of-type {
  padding-top: 0;
  margin-top: 0;
  border-top: none;
}

.subfield-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.subfield-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

.subfield-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.subfield-hint {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: #999;
}

.recipe-inline-row {
  display: flex;
  gap: 32rpx;
}

.recipe-inline-field {
  flex: 1;
}

/* 菜谱 textarea */
.recipe-textarea {
  width: 100%;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  padding: 0;
  box-sizing: border-box;
}

/* 分类选择器 */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: #333;
  border-bottom: 2rpx solid #E8F5E9;
}

.picker-arrow {
  font-size: 36rpx;
  color: #CCC;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-reset {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: #666;
  background: #F5F5F5;
  border-radius: 50rpx;
  margin-right: 20rpx;
}

.btn-save {
  flex: 2;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: white;
  background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%);
  border-radius: 50rpx;
  font-weight: 500;
}
