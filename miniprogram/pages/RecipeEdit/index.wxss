/* 菜谱编辑页样式 */

.container {
  padding-bottom: 200rpx;
}

/* 页面头部 */
.page-header {
  padding: 40rpx 40rpx 24rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
}

.page-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  padding: 0 24rpx;
}

.input-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(124, 179, 66, 0.12);
}

.input-card.half {
  flex: 1;
}

.input-row {
  display: flex;
  gap: 24rpx;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.label-optional {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #BBB;
}

.input-field {
  width: 100%;
  font-size: 30rpx;
  color: #333;
  padding: 8rpx 0;
}

.input-textarea {
  width: 100%;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  padding: 0;
  box-sizing: border-box;
}

.input-placeholder {
  color: #CCC;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  color: #333;
  padding: 8rpx 0;
}

.picker-arrow {
  color: #BBB;
  font-size: 36rpx;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(245, 249, 240, 0.95);
  backdrop-filter: blur(10px);
}

.btn-save {
  padding: 28rpx;
  background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%);
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(111, 207, 151, 0.3);
}

.btn-save text {
  font-size: 32rpx;
  color: white;
  font-weight: 500;
}

.btn-disabled {
  opacity: 0.6;
}
